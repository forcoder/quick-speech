# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.2.0
#
# Required ENV vars:
# ------------------
#   JAVA_HOME - location of a JDK home dir
#
# Optional ENV vars
# -----------------
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
#     e.g. to debug Maven itself, use
#       set MAVEN_OPTS=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000
#   MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_SKIP_RC" ] ; then

  if [ -f /usr/local/etc/mavenrc ] ; then
    . /usr/local/etc/mavenrc
  fi

  if [ -f /etc/mavenrc ] ; then
    . /etc/mavenrc
  fi

  if [ -f "$HOME/.mavenrc" ] ; then
    . "$HOME/.mavenrc"
  fi

fi

# OS specific support.  $var _must_ be set to either true or false.
cygwin=false;
mingw=false;
msys=false;
darwin=false;
nonstop=false;
case "$(uname)" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MSYS* | MINGW* )
    msys=true
    mingw=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

if [ -z "$JAVA_HOME" ] ; then
  if [ -d "/usr/lib/jvm/java-17-openjdk-amd64" ] ; then
    JAVA_HOME="/usr/lib/jvm/java-17-openjdk-amd64"
  elif [ -d "/usr/lib/jvm/java-17-oracle" ] ; then
    JAVA_HOME="/usr/lib/jvm/java-17-oracle"
  elif [ -d "/usr/lib/jvm/java-17" ] ; then
    JAVA_HOME="/usr/lib/jvm/java-17"
  elif [ -d "/usr/java/jdk-17" ] ; then
    JAVA_HOME="/usr/java/jdk-17"
  fi
fi

if [ -z "$JAVA_HOME" ] ; then
  javaExecutable="$(which java)"
  if [ -n "$javaExecutable" ] && ! [ -z "$javaExecutable" ] ; then
    javaExecutable="$(readlink -f "$javaExecutable")"
    JAVA_HOME="$(dirname "$(dirname "$javaExecutable")")"
    if [ ! -x "$JAVA_HOME/bin/java" ] ; then
      echo "The java command from PATH does not resolve to a valid JVM home directory." >&2
      echo "JAVA_HOME is not set and could not be automatically determined from PATH." >&2
      echo "Please set JAVA_HOME." >&2
      javaExecutable=""; unset javaExecutable
      exit 1
    fi
  else
    echo "JAVA_HOME not set." >&2
    echo "Please set JAVA_HOME." >&2
    exit 1
  fi
  unset javaExecutable
fi

CLASSPATH="$JAVA_HOME/lib/tools.jar"

if [ -f "$JAVA_HOME/lib/tools.jar" ] ; then
  CLASSPATH="$JAVA_HOME/lib/tools.jar"
fi

if [ -z "$JAVACMD" ] ; then
  if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
  else
    JAVACMD="java"
  fi
fi

if [ ! -x "$JAVACMD" ] ; then
  echo "The JAVA_HOME environment variable is not defined correctly," >&2
  echo "so mvnw cannot start." >&2
  exit 1
fi

if [ -z "$MAVEN_PROJECTBASEDIR" ] ; then
  MAVEN_PROJECTBASEDIR="$(pwd)"
fi

if [ -n "$JAVA_HOME" ] ; then
  if [ -f "$JAVA_HOME/lib/tools.jar" ] ; then
    CLASSPATH="$JAVA_HOME/lib/tools.jar"
  fi
fi

WRAPPER_JAR=""
WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

if [ -f "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" ] ; then
  WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
fi

if [ -z "$WRAPPER_JAR" ] ; then
  if [ -f "$HOME/.m2/wrapper/dists/apache-maven-3.9.6-bin/*/apache-maven-3.9.6/lib/maven-wrapper-3.2.0.jar" ] ; then
    WRAPPER_JAR="$(echo "$HOME/.m2/wrapper/dists/apache-maven-3.9.6-bin/"*"/apache-maven-3.9.6/lib/maven-wrapper-3.2.0.jar)"
  fi
fi

if [ -z "$WRAPPER_JAR" ] ; then
  if [ -n "$MVNW_REPOURL" ] ; then
    DOWNLOAD_URL="$MVNW_REPOURL/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
  else
    DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
  fi
  echo "Downloading from: $DOWNLOAD_URL" >&2
  WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
  if command -v wget > /dev/null 2>&1 ; then
    wget -q -O "$WRAPPER_JAR" "$DOWNLOAD_URL"
  elif command -v curl > /dev/null 2>&1 ; then
    curl -s -o "$WRAPPER_JAR" "$DOWNLOAD_URL"
  else
    echo "Could not download maven-wrapper.jar because neither wget nor curl is available." >&2
    exit 1
  fi
fi

export MAVEN_PROJECTBASEDIR

exec "$JAVACMD" \
  $MAVEN_OPTS \
  $MAVEN_DEBUG_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  $WRAPPER_LAUNCHER \
  $MAVEN_CONFIG \
  "$@"
